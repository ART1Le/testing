-- =============================================
-- LOGIC
-- =============================================
local function GetPath(obj)
    local p = {}
    local c = obj
    while c and c ~= game do table.insert(p, 1, c.Name); c = c.Parent end
    return table.concat(p, ".")
end

local function GetVector3()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    return hrp and hrp.Position or nil
end

local function UpdateUI(obj)
    if not obj or not obj.Parent then return end
    if obj:IsDescendantOf(ScreenGui) then return end

    local absPos = obj.AbsolutePosition or Vector2.new(0,0)
    local v3 = GetVector3()

    resultData.name   = obj.Name
    resultData.path   = GetPath(obj)
    resultData.type   = obj.ClassName
    resultData.screen = string.format("X:%d, Y:%d", absPos.X, absPos.Y)
    
    if v3 then
        resultData.vec3 = string.format("Vector3.new(%.2f, %.2f, %.2f)", v3.X, v3.Y, v3.Z)
    else
        resultData.vec3 = "N/A"
    end

    RowName.Text   = resultData.name
    RowPath.Text   = resultData.path
    RowType.Text   = resultData.type
    RowScreen.Text = resultData.screen
    RowVec3.Text   = resultData.vec3

    Title.Text = "🟢 DETECTED: " .. obj.Name
    Title.TextColor3 = Color3.fromRGB(100, 255, 100)
    task.delay(1, function()
        Title.Text = "🔴 RECORDING: Tap Any UI Element"
        Title.TextColor3 = Color3.fromRGB(255, 100, 100)
    end)
end

-- METHOD 1: Track Any GUI Interaction (Paling Ampuh di Mobile)
-- Menggunakan InputBegan pada level GUI secara global
UIS.InputBegan:Connect(function(input, processed)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        
        -- Beri jeda sedikit agar game memproses klik/tap-nya
        task.wait(0.05) 
        
        -- Ambil semua GUI di posisi jari kita
        local pos = input.Position
        local guisAtPosition = PlayerGui:GetGuiObjectsAtPosition(pos.X, pos.Y)
        
        -- Filter hasil
        for _, gui in ipairs(guisAtPosition) do
            -- Abaikan background transparan/frame penutup layar utuh
            if gui.BackgroundTransparency < 1 or gui:IsA("TextButton") or gui:IsA("ImageButton") or gui:IsA("TextBox") or gui:IsA("TextLabel") or gui:IsA("ImageLabel") then
                UpdateUI(gui)
                break -- Hanya ambil yang paling atas
            end
        end
    end
end)

-- METHOD 2: Inject Event langusng ke button
-- Berguna jika game memblokir GetGuiObjectsAtPosition
local function HookButton(btn)
    if btn:IsA("GuiObject") then
        pcall(function()
            -- Listeners
            if btn:IsA("TextButton") or btn:IsA("ImageButton") then
                btn.MouseButton1Down:Connect(function() UpdateUI(btn) end)
                btn.Activated:Connect(function() UpdateUI(btn) end)
            end
            
            -- Mobile touch spesifik
            btn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                    UpdateUI(btn)
                end
            end)
        end)
    end
end

-- Scan existing & future UI
local function Scan(parent)
    for _, child in ipairs(parent:GetDescendants()) do HookButton(child) end
    parent.DescendantAdded:Connect(HookButton)
end
Scan(PlayerGui)

print("✅ DetectButtonGUI v4 (Ultimate) Aktif!")
