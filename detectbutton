CopyAllBtn.MouseButton1Click:Connect(function()
    if not next(resultData) then return end
    local all = table.concat({
        "BUTTON  : " .. (resultData.button or "—"),
        "PATH    : " .. (resultData.path   or "—"),
        "SCREEN  : " .. (resultData.screen or "—"),
        "XYZ     : " .. (resultData.xyz    or "—"),
        "Vector3 : " .. (resultData.vec3   or "—"),
    }, "\n")
    if setclipboard then
        setclipboard(all)
        CopyAllBtn.Text = "✅  COPIED!"
        CopyAllBtn.BackgroundColor3 = Color3.fromRGB(40, 100, 60)
        task.delay(1.5, function()
            CopyAllBtn.Text = "📋  COPY ALL"
            CopyAllBtn.BackgroundColor3 = Color3.fromRGB(70, 50, 130)
        end)
    end
end)

-- =============================================
-- Helper fungsi
-- =============================================
local function GetPath(obj)
    local parts = {}
    local cur = obj
    while cur and cur ~= game do
        table.insert(parts, 1, cur.Name)
        cur = cur.Parent
    end
    return table.concat(parts, " > ")
end

local function GetXYZ()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    return hrp and hrp.Position or nil
end

-- =============================================
-- Connect setiap button
-- =============================================
local function ConnectButton(btn)
    if not (btn:IsA("TextButton") or btn:IsA("ImageButton")) then return end

    btn.MouseButton1Click:Connect(function()
        local absPos = btn.AbsolutePosition
        local xyz    = GetXYZ()

        resultData.button = btn.Name .. (btn.Text ~= "" and (' ("'..btn.Text..'")') or "")
        resultData.path   = GetPath(btn)
        resultData.screen = string.format("X=%d | Y=%d", absPos.X, absPos.Y)

        if xyz then
            resultData.xyz  = string.format("X=%.2f | Y=%.2f | Z=%.2f", xyz.X, xyz.Y, xyz.Z)
            resultData.vec3 = string.format("Vector3.new(%.3f, %.3f, %.3f)", xyz.X, xyz.Y, xyz.Z)
        else
            resultData.xyz  = "karakter tidak ditemukan"
            resultData.vec3 = "—"
        end

        -- Update UI
        RowButton.Text = resultData.button
        RowPath.Text   = resultData.path
        RowScreen.Text = resultData.screen
        RowXYZ.Text    = resultData.xyz
        RowVec3.Text   = resultData.vec3

        -- Print ke console juga
        print("[DetectGUI] " .. resultData.button .. " | " .. resultData.vec3)
    end)
end

local function ScanGui(guiObj)
    for _, obj in ipairs(guiObj:GetDescendants()) do ConnectButton(obj) end
    guiObj.DescendantAdded:Connect(function(obj) task.wait(); ConnectButton(obj) end)
end

for _, gui in ipairs(PlayerGui:GetChildren()) do
    if gui ~= ScreenGui then ScanGui(gui) end
end

PlayerGui.ChildAdded:Connect(function(gui)
    if gui == ScreenGui then return end
    task.wait(0.3)
    ScanGui(gui)
end)

print("✅ DetectButtonGUI UI aktif! Tap button apapun.")
