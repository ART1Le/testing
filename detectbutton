local function ManageHighlight(instance, color)
    if not instance then return end
    if not ESP_Cache[instance] then
        local hl = Instance.new("Highlight")
        hl.Adornee = instance
        hl.FillColor = color
        hl.FillTransparency = 0.5
        hl.OutlineColor = Color3.new(1, 1, 1)
        hl.OutlineTransparency = 0
        hl.Parent = ESPFolder
        ESP_Cache[instance] = hl
    else
        ESP_Cache[instance].FillColor = color 
    end
    return ESP_Cache[instance]
end

local function ManageLabel(instance, text, color)
    if not instance or text == "" then return end
    if not Label_Cache[instance] then
        local bgui = Instance.new("BillboardGui")
        bgui.AlwaysOnTop = true
        bgui.Size = UDim2.new(0, 200, 0, 60)
        bgui.StudsOffset = Vector3.new(0, 4, 0)
        
        local txt = Instance.new("TextLabel")
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Font = Enum.Font.GothamBold
        txt.TextSize = 12
        txt.TextStrokeTransparency = 0
        txt.TextYAlignment = Enum.TextYAlignment.Bottom
        txt.Parent = bgui
        
        bgui.Parent = ESPFolder
        bgui.Adornee = instance
        Label_Cache[instance] = bgui
    end
    
    local textLabel = Label_Cache[instance]:FindFirstChildOfClass("TextLabel")
    if textLabel then
        textLabel.Text = text
        textLabel.TextColor3 = color
    end
    return Label_Cache[instance]
end

local function GetExtraInfo(targetArray, targetName)
