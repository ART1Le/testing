-- Drag support
local dragging, dragInput, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
TitleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- =============================================
-- Helper: Buat baris hasil + tombol copy
-- =============================================
local rowY = 44
local resultData = {} -- simpan data terakhir

local function MakeRow(labelText, flagKey, color)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, -12, 0, 36)
    container.Position = UDim2.new(0, 6, 0, rowY)
    container.BackgroundColor3 = Color3.fromRGB(30, 30, 42)
    container.BorderSizePixel = 0
    container.Parent = MainFrame
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0, 70, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = color or Color3.fromRGB(140, 140, 180)
    lbl.TextSize = 11
    lbl.Font = Enum.Font.GothamBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Position = UDim2.new(0, 8, 0, 0)
    lbl.Parent = container

    local val = Instance.new("TextLabel")
    val.Size = UDim2.new(1, -150, 1, 0)
    val.Position = UDim2.new(0, 78, 0, 0)
    val.BackgroundTransparency = 1
    val.Text = "—"
    val.TextColor3 = Color3.fromRGB(230, 230, 255)
    val.TextSize = 11
    val.Font = Enum.Font.Gotham
    val.TextXAlignment = Enum.TextXAlignment.Left
    val.TextTruncate = Enum.TextTruncate.AtEnd
    val.Parent = container

    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0, 56, 0, 24)
    copyBtn.Position = UDim2.new(1, -62, 0.5, -12)
    copyBtn.BackgroundColor3 = Color3.fromRGB(55, 55, 90)
    copyBtn.Text = "COPY"
    copyBtn.TextColor3 = Color3.fromRGB(200, 200, 255)
    copyBtn.TextSize = 10
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.BorderSizePixel = 0
    copyBtn.Parent = container
    Instance.new("UICorner", copyBtn).CornerRadius = UDim.new(0, 4)

    copyBtn.MouseButton1Click:Connect(function()
        if resultData[flagKey] and setclipboard then
            setclipboard(resultData[flagKey])
            copyBtn.Text = "✓ OK"
            copyBtn.BackgroundColor3 = Color3.fromRGB(40, 100, 60)
            task.delay(1.5, function()
                copyBtn.Text = "COPY"
                copyBtn.BackgroundColor3 = Color3.fromRGB(55, 55, 90)
            end)
        end
    end)

    rowY = rowY + 42
    return val
end

-- Buat semua baris
local RowButton  = MakeRow("BUTTON",  "button",  Color3.fromRGB(255, 200, 80))
local RowPath    = MakeRow("PATH",    "path",    Color3.fromRGB(100, 200, 255))
local RowScreen  = MakeRow("SCREEN",  "screen",  Color3.fromRGB(180, 255, 180))
local RowXYZ     = MakeRow("XYZ",     "xyz",     Color3.fromRGB(255, 150, 150))
local RowVec3    = MakeRow("Vector3", "vec3",    Color3.fromRGB(255, 180, 255))

-- Tombol COPY ALL
local CopyAllBtn = Instance.new("TextButton")
CopyAllBtn.Size = UDim2.new(1, -12, 0, 30)
CopyAllBtn.Position = UDim2.new(0, 6, 0, rowY + 2)
CopyAllBtn.BackgroundColor3 = Color3.fromRGB(70, 50, 130)
CopyAllBtn.Text = "📋  COPY ALL"
