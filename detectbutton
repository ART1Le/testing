RunService.Heartbeat:Connect(function()
    -- Hide Identity Logic
    if HideIdentityEnabled then
        pcall(function()
            local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
            if playerGui then
                -- Hide Survivor UI
                local survUI = playerGui:FindFirstChild("Survivor")
                if survUI and survUI:FindFirstChild("Frame") then
                    for i = 1, 5 do
                        local survNum = survUI.Frame:FindFirstChild("Survivor" .. i)
                        if survNum and survNum:FindFirstChild("TextLabel") then
                            if survNum.TextLabel.Text ~= "Lany Labs" and survNum.TextLabel.Text ~= "" then
                                survNum.TextLabel.Text = "Lany Labs"
                            end
                        end
                    end
                end
                
                -- Hide Spectator UI
                local specUI = playerGui:FindFirstChild("Spectator")
                if specUI and specUI:FindFirstChild("Info") and specUI.Info:FindFirstChild("Your") then
                    local usernameTxt = specUI.Info.Your:FindFirstChild("Username")
                    if usernameTxt and usernameTxt.Text ~= "Lany Labs" then
                        usernameTxt.Text = "Lany Labs"
                    end
                end
            end
        end)
    end

    -- Fast Vault Logic
    if FastVaultEnabled and LocalPlayer.Team and LocalPlayer.Team.Name == "Survivors" then
        if LocalPlayer.Character then
            pcall(function()
                LocalPlayer.Character:SetAttribute("vaultspeed", 2)
                local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
                if playerGui then
                    local pcprompts = playerGui:FindFirstChild("pcprompts")
                    if pcprompts then
                        local vaultPrompt = pcprompts:FindFirstChild("VaultPromptGui")
                        if vaultPrompt and vaultPrompt.Visible then
                            LocalPlayer.Character:SetAttribute("IsRunning", true)
                        end
                    end
                end
            end)
        end
    end

    -- Auto Skill Check Logic
    if AutoSkillCheck and LocalPlayer.Team and LocalPlayer.Team.Name == "Survivors" then
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            for _, guiName in pairs({"SkillCheckPromptGui", "SkillCheckPromptGui-con"}) do
                local promptGui = playerGui:FindFirstChild(guiName)
                if promptGui then
                    local checkFrame = promptGui:FindFirstChild("Check")
                    if checkFrame and checkFrame.Visible then
                        local line = checkFrame:FindFirstChild("Line")
                        local goal = checkFrame:FindFirstChild("Goal")
                        if line and goal and not isPressing then
                            local lr = line.Rotation % 360
                            local gr = goal.Rotation % 360
                            local gs = (gr + 104) % 360
                            local ge = (gr + 114) % 360

                            local inGoal = false
                            if gs > ge then inGoal = (lr >= gs or lr <= ge) else inGoal = (lr >= gs and lr <= ge) end

                            if inGoal then
                                isPressing = true
                                pcall(function()
                                    -- 1. Eksekusi PC (Spacebar)
                                    vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                                    task.wait(0.01)
                                    vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)

                                    -- 2. Eksekusi Mobile (Tap Langsung ke Tombol/Elemen)
                                    -- Cara A: Jika game membuat TextButton/ImageButton spesifik di Mobile
                                    for _, btn in ipairs(promptGui:GetDescendants()) do
                                        if btn:IsA("TextButton") or btn:IsA("ImageButton") then
                                            if firesignal then
                                                pcall(function() firesignal(btn.MouseButton1Click) end)
                                                pcall(function() firesignal(btn.Activated) end)
                                            end
                                            if getconnections then
                                                for _, conn in pairs(getconnections(btn.MouseButton1Click) or {}) do
                                                    if type(conn.Function) == "function" then pcall(conn.Function) end
                                                end
                                            end
                                        end
                                    end

                                    -- Cara B: Tap Tepat di Lingkaran/UI Skill Check
                                    if checkFrame then
                                        local tapX = checkFrame.AbsolutePosition.X + (checkFrame.AbsoluteSize.X / 2)
                                        local tapY = checkFrame.AbsolutePosition.Y + (checkFrame.AbsoluteSize.Y / 2)
                                        
                                        vim:SendMouseButtonEvent(tapX, tapY, 0, true, game, 1)
                                        task.wait(0.01)
                                        vim:SendMouseButtonEvent(tapX, tapY, 0, false, game, 1)
                                    end
                                    
                                    -- 3. Fallback Exploit Level
                                    if mouse1click then task.spawn(mouse1click) end
                                end)
                                task.delay(1, function() isPressing = false end)
                            end
                        end
                    end
                end
            end
        end
    end

    -- ESP LOGIC
    if not ESPSettings.Enabled then
        for inst, hl in pairs(ESP_Cache) do hl:Destroy(); ESP_Cache[inst] = nil end
        for inst, lbl in pairs(Label_Cache) do lbl:Destroy(); Label_Cache[inst] = nil end
        return
    end

    local function IsTargeted(t)
        for _, v in pairs(ESPSettings.Targets) do
            if v == t then return true end
        end return false
    end

    local activeHighlights = {} 
    local activeLabels = {}

    -- 1. Scan Players
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            if IsTargeted("Killer") and plr.Team and plr.Team.Name == "Killer" then
                activeHighlights[plr.Character] = Color3.fromRGB(255, 50, 50)
                
            elseif IsTargeted("Survivor") and plr.Team and plr.Team.Name == "Survivors" then
                activeHighlights[plr.Character] = Color3.fromRGB(50, 200, 255)
                
                -- Text Info for Survivor
                local textData = plr.Name
                if GetExtraInfo(ExtraESPInfo, "Weapon Info") then
                    local heldItem = "None"
                    for _, child in pairs(plr.Character:GetChildren()) do
                        if WeaponDict[child.Name] then
                            heldItem = WeaponDict[child.Name]
                            break
                        end
                    end
                    if heldItem ~= "None" then
                        textData = textData .. "\nItem: " .. heldItem
                    end
                end
                
                if GetExtraInfo(ExtraESPInfo, "Hook Count") then
                    local hooks = plr.Character:GetAttribute("HookCount") or 0
                    textData = textData .. "\nHook: " .. tostring(hooks)
                end
                
                if GetExtraInfo(ExtraESPInfo, "Heal Progress") then
                    local heal = plr.Character:GetAttribute("HealProgress") or 0
                    textData = textData .. "\nHeal: " .. string.format("%.1f", heal) .. "%"
                end
                
                if textData ~= plr.Name then
                    activeLabels[plr.Character] = {text = textData, color = Color3.fromRGB(50, 200, 255)}
                end
            end
        end
    end

    -- 2. Scan Map Objects
    local mapFolder = workspace:FindFirstChild("Map")
    if mapFolder then
        local targetObjects = {}
        
        -- Fitur scan ringan (Max 3 Level) agar tidak lag tanpa GetDescendants!
        for _, obj1 in ipairs(mapFolder:GetChildren()) do
            table.insert(targetObjects, obj1)
            if obj1:IsA("Folder") or obj1:IsA("Model") then
                for _, obj2 in ipairs(obj1:GetChildren()) do
                    table.insert(targetObjects, obj2)
                    if obj2:IsA("Folder") or obj2:IsA("Model") then
                        for _, obj3 in ipairs(obj2:GetChildren()) do
                            table.insert(targetObjects, obj3)
                        end
                    end
                end
            end
        end

        for _, obj in ipairs(targetObjects) do
            -- Generator
                if IsTargeted("Generator") and string.match(obj.Name, "Generator") then
                    local isDone = false
                    local repairProg = obj:GetAttribute("RepairProgress")
                    
                    if repairProg and repairProg >= 100 then isDone = true end

                    local pointLight = obj:FindFirstChild("PointLight", true)
                    if pointLight then
                        local r = math.floor(pointLight.Color.R * 255 + 0.5)
                        local g = math.floor(pointLight.Color.G * 255 + 0.5)
                        local b = math.floor(pointLight.Color.B * 255 + 0.5)
                        if r == 126 and g == 255 and b == 126 then isDone = true end
                    end
                    
                    if not isDone then 
                        activeHighlights[obj] = Color3.fromRGB(255, 200, 50) 
                        
                        if GetExtraInfo(ExtraESPInfo, "Repair Progress") then
                            local currentProg = repairProg or 0
                            local textData = string.format("Gen: %.1f%%", currentProg)
                            activeLabels[obj] = {text = textData, color = Color3.fromRGB(255, 200, 50)}
                        end
                    end

                -- Pallet
                elseif IsTargeted("Pallet") and string.match(obj.Name, "Palletwrong") then
                    local isUsed = obj:FindFirstChild("PalletPointSlide", true)
                    if isUsed then
                        activeHighlights[obj] = Color3.fromRGB(200, 100, 50)
                        activeLabels[obj] = {text = "Dropped Pallet", color = Color3.fromRGB(200, 100, 50)}
                    else
                        activeHighlights[obj] = Color3.fromRGB(255, 150, 50)
                        activeLabels[obj] = {text = "Pallet", color = Color3.fromRGB(255, 150, 50)}
                    end

                -- Hook
                elseif IsTargeted("Hook") and string.match(obj.Name, "Hook") then
                    activeHighlights[obj] = Color3.fromRGB(255, 0, 255)
                
                -- Gate
                elseif IsTargeted("Gate") and string.match(obj.Name, "Gate") then
                    activeHighlights[obj] = Color3.fromRGB(50, 255, 100)
                end
            end
        end
    end

    -- 4. Apply/Update ESP
    for inst, color in pairs(activeHighlights) do ManageHighlight(inst, color) end
    for inst, data in pairs(activeLabels) do ManageLabel(inst, data.text, data.color) end

    -- 5. Clean up ESP
    for inst, hl in pairs(ESP_Cache) do
        if not activeHighlights[inst] then hl:Destroy(); ESP_Cache[inst] = nil end
    end
    for inst, lbl in pairs(Label_Cache) do
        if not activeLabels[inst] then lbl:Destroy(); Label_Cache[inst] = nil end
    end
end)

